# Elyvn Environment Variables
# Use exactly these 12 variables

# Server configuration
PORT=3000

# Database
DATABASE_URL=./elyvn.sqlite

# Retell Configuration
RETELL_API_KEY=your_retell_api_key
RETELL_AGENT_ID=your_retell_agent_id

# Twilio Configuration
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# Telegram Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Business Configuration
BUSINESS_NAME=Elyvn
BUSINESS_HOURS=Mon-Fri 9am-5pm
BOOKING_LINK=https://calendly.com/your-link

# Cal.com Configuration
CALCOM_API_KEY=your_calcom_api_key
CALCOM_EVENT_TYPE_ID=your_calcom_event_type_id

# Call Transfer
TRANSFER_PHONE_NUMBER=your_transfer_phone_number

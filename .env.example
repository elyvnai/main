# ===========================================
# ELYVN ENVIRONMENT CONFIGURATION
# ===========================================
# Copy this file to .env and fill in your values
# All sensitive data should be stored in .env and never committed to version control

# ===========================================
# SERVER CONFIGURATION
# ===========================================
PORT=3000
NODE_ENV=development

# ===========================================
# DATABASE
# ===========================================
DATABASE_URL=./data/elyvn.sqlite

# ===========================================
# RETELL AI CONFIGURATION
# ===========================================
# API key from Retell dashboard
RETELL_API_KEY=your_retell_api_key_here
# The agent ID to sync prompts and tools with
RETELL_AGENT_ID=your_retell_agent_id_here
# Webhook secret for verifying incoming Retell webhooks
RETELL_WEBHOOK_SECRET=your_webhook_secret_here

# ===========================================
# TWILIO CONFIGURATION (SMS & Voice)
# ===========================================
# Twilio account credentials from console.twilio.com
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
# Your Twilio phone number (E.164 format, e.g., +1234567890)
TWILIO_PHONE_NUMBER=+1234567890

# ===========================================
# TELEGRAM BOT CONFIGURATION
# ===========================================
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Your Telegram chat ID (get it from @userinfobot)
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ===========================================
# BUSINESS CONFIGURATION
# ===========================================
# Your business name (used in AI prompts, SMS, and notifications)
BUSINESS_NAME=Elyvn
# Your business phone number (displayed to customers)
BUSINESS_PHONE_NUMBER=+1234567890
# Operating hours (used in AI prompts and SMS)
BUSINESS_HOURS=Mon-Fri 9:00 AM - 5:00 PM
# Online booking link (Cal.com or other scheduling tool)
BOOKING_LINK=https://calendly.com/your-company/appointment

# ===========================================
# CAL.COM INTEGRATION
# ===========================================
# API key from app.cal.com/settings/api
CALCOM_API_KEY=your_calcom_api_key_here
# Event type ID for appointments (found in Cal.com URL)
CALCOM_EVENT_TYPE_ID=your_calcom_event_type_id_here

# ===========================================
# CALL TRANSFER CONFIGURATION
# ===========================================
# Phone number to transfer calls to when human assistance is requested
# Format: E.164 (e.g., +1234567890)
TRANSFER_PHONE_NUMBER=+1234567890

# ===========================================
# SPEED-TO-LEAD SETTINGS
# ===========================================
# Time window (in seconds) to send SMS after a missed call
# Default: 60 seconds
SPEED_TO_LEAD_WINDOW=60
# Whether speed-to-lead is enabled (true/false)
SPEED_TO_LEAD_ENABLED=true

# ===========================================
# SMS KEYWORD CONFIGURATION
# ===========================================
# Keywords that trigger SMS opt-out (comma-separated)
# Customers texting these will be opted out of SMS
SMS_OPT_OUT_KEYWORDS=STOP,END,UNSUBSCRIBE,CANCEL
# Keyword to request a callback
SMS_CALLBACK_KEYWORD=CALLBACK
# Keyword to mark a lead as urgent
SMS_URGENT_KEYWORD=URGENT

# ===========================================
# OPTIONAL: TWILIO MESSAGING SETTINGS
# ===========================================
# Status callback URL for SMS delivery reports
TWILIO_STATUS_CALLBACK=https://your-domain.com/webhooks/twilio/status
# Maximum SMS segment length (default: 160 for single SMS)
SMS_MAX_LENGTH=160

# ===========================================
# OPTIONAL: RETELL ADVANCED SETTINGS
# ===========================================
# Override default Retell API base URL (usually not needed)
# RETELL_API_BASE_URL=https://api.retell.ai/v1

# ===========================================
# OPTIONAL: DEBUGGING & LOGGING
# ===========================================
# Enable verbose logging (true/false)
VERBOSE_LOGGING=false
# Enable detailed error reporting to Telegram (true/false)
ERROR_REPORTING_ENABLED=true

# Core
PORT=3001
NODE_ENV=production
DATABASE_PATH=/data/elyvn.db

# Retell AI
RETELL_API_KEY=your_retell_api_key_here
RETELL_WEBHOOK_SECRET=your_retell_webhook_secret_here

# Twilio (ONE number for calls + SMS)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+15550199

# Cal.com
CALCOM_API_KEY=your_calcom_api_key_here

# Telegram (ONE bot for ALL clients)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_WEBHOOK_SECRET=your_telegram_webhook_secret_here

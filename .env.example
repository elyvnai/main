# Elyvn Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# SERVER CONFIGURATION
# ===========================================
PORT=3000
NODE_ENV=development

# ===========================================
# DATABASE
# ===========================================
DATABASE_URL=./data/elyvn.sqlite

# ===========================================
# RETELL AI CONFIGURATION
# ===========================================
RETELL_API_KEY=your_retell_api_key_here
RETELL_AGENT_ID=your_retell_agent_id_here

# ===========================================
# TWILIO CONFIGURATION (SMS & Voice)
# ===========================================
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ===========================================
# TELEGRAM BOT CONFIGURATION
# ===========================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ===========================================
# BUSINESS CONFIGURATION
# ===========================================
BUSINESS_NAME=Elyvn
BUSINESS_HOURS=Mon-Fri 9:00 AM - 5:00 PM
BOOKING_LINK=https://calendly.com/your-company/appointment

# ===========================================
# CAL.COM INTEGRATION
# ===========================================
CALCOM_API_KEY=your_calcom_api_key_here
CALCOM_EVENT_TYPE_ID=your_calcom_event_type_id

# ===========================================
# CALL TRANSFER CONFIGURATION
# ===========================================
TRANSFER_PHONE_NUMBER=+1234567890

# ===========================================
# SPEED-TO-LEAD SETTINGS
# ===========================================
# Time window (in seconds) to send SMS after a missed call
SPEED_TO_LEAD_WINDOW=60
# Whether speed-to-lead is enabled (true/false)
SPEED_TO_LEAD_ENABLED=true

# ===========================================
# OPTIONAL: ADDITIONAL SERVICES
# ===========================================
# Retell AI Webhook Secret (for verifying webhook requests)
RETELL_WEBHOOK_SECRET=your_webhook_secret_here

# SMS Opt-out Keywords (comma-separated, default: STOP,END,UNSUBSCRIBE)
SMS_OPT_OUT_KEYWORDS=STOP,END,UNSUBSCRIBE

# Callback Request Keyword
SMS_CALLBACK_KEYWORD=CALLBACK

# Urgent Priority Keyword
SMS_URGENT_KEYWORD=URGENT